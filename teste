<script>
// ============================================================
//  DATA & CONFIG
// ============================================================
const MONTH_CONFIGS = {
  "Junho/2025": {
    month: "Junho/2025",
    globalTarget: 132000,
    sectorDistribution: { counter: 0.70, teleformula: 0.30 },
    kpiTargets: { avgTicket: 132, conversionRate: 0.84 },
    churnMax: 20,
    prospMin: 5000,
    postSaleMin: 25,
    weeklyBonuses: [100, 100, 100, 100],
    monthlyBonuses: { conversion: 100, avgTicket: 180, type: 'vale-jantar' },
    hatTrick: { type: 'fixed', value: 50 },
    commissionRates: {
      counter: { 0.90: 0.003, 1.00: 0.004, 1.10: 0.006, def: 0.002 },
      teleformula: { 0.90: 0.003, 1.00: 0.004, 1.10: 0.006, def: 0.002 }
    },
    salesChannels: {
      "Prescrição": 0.30, "Prospecção": 0.12, "Ações": 0.12, "Orgânico": 0.46
    }
  },
  "Setembro/2025": {
    month: "Setembro/2025",
    globalTarget: 180000,
    sectorDistribution: { counter: 0.70, teleformula: 0.30 },
    kpiTargets: { avgTicket: 160, conversionRate: 0.85 },
    churnMax: 20,
    prospMin: 5000,
    postSaleMin: 25,
    weeklyBonuses: [110, 120, 120, 100],
    monthlyBonuses: { conversion: 50, avgTicket: 50, type: 'dinheiro' },
    hatTrick: { type: 'percent', value: 0.50 },
    commissionRates: {
      counter: { 0.90: 0.003, 1.00: 0.004, 1.10: 0.006, def: 0.002 },
      teleformula: { 0.90: 0.005, 1.00: 0.007, 1.10: 0.01, def: 0.002 }
    },
    salesChannels: {
      "Novas Prescrições": 0.62, "Prospecção Ativa": 0.05, "Pós-venda": 0.10, "Ações": 0.10, "Orgânico": 0.13
    }
  }
};

let activeMonth = "Setembro/2025";
let config = JSON.parse(JSON.stringify(MONTH_CONFIGS[activeMonth]));

let employees = [
  { id:1, name:"Ana Lima", sector:"counter", color:"#1a6b3c", days:30, fat:28500, orc:220, vend:189, postSale:28 },
  { id:2, name:"Bruna Costa", sector:"counter", color:"#2563eb", days:30, fat:31200, orc:240, vend:210, postSale:31 },
  { id:3, name:"Carla Souza", sector:"teleformula", color:"#7c3aed", days:30, fat:19800, orc:160, vend:142, postSale:26 },
  { id:4, name:"Diego Matos", sector:"counter", color:"#b45309", days:30, fat:26700, orc:210, vend:178, postSale:22 },
  { id:5, name:"Eliana Reis", sector:"teleformula", color:"#be123c", days:30, fat:17600, orc:138, vend:115, postSale:19 },
  { id:6, name:"Jailda Ferreira", sector:"counter", color:"#0e7490", days:10, fat:8900, orc:72, vend:61, postSale:9 }
];

let weeklyAchieved = [1, 1, 0, 0]; // 1=atingiu, 0=não atingiu

let monthlyData = {
  fat: 0, orc: 0, vend: 0, churn: 12, prospValue: 6200, postSaleDay: 27
};

let historicalData = {
  labels: ["Mar", "Abr", "Mai", "Jun", "Jul", "Ago", "Set"],
  fat: [95000, 108000, 121000, 118500, 143000, 159000, 132900],
  target: [110000, 120000, 130000, 132000, 150000, 165000, 180000]
};

let charts = {};
let checklistState = {};

// ============================================================
//  UTILS
// ============================================================
const fmt = (n) => n.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL', minimumFractionDigits: 0, maximumFractionDigits: 0 });
const fmtP = (n) => (n * 100).toFixed(1) + '%';
const pct = (v, t) => t > 0 ? Math.min(100, Math.round(v / t * 100)) : 0;

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

function calcEmployeeMeta(emp) {
  const sectorTarget = config.globalTarget * config.sectorDistribution[emp.sector === 'counter' ? 'counter' : 'teleformula'];
  const empCount = employees.filter(e => e.sector === emp.sector).length;
  const dailyBase = sectorTarget / (empCount * 30);
  return dailyBase * emp.days;
}

function calcCommission(emp) {
  const meta = calcEmployeeMeta(emp);
  const ratio = meta > 0 ? emp.fat / meta : 0;
  const rates = config.commissionRates[emp.sector === 'counter' ? 'counter' : 'teleformula'];
  let rate;
  if (ratio >= 1.10) rate = rates[1.10];
  else if (ratio >= 1.00) rate = rates[1.00];
  else if (ratio >= 0.90) rate = rates[0.90];
  else rate = rates.def;
  return emp.fat * rate;
}

function getProgressColor(pct) {
  if (pct >= 100) return 'progress-green';
  if (pct >= 80) return 'progress-yellow';
  return 'progress-red';
}
function getPillClass(pct) {
  if (pct >= 100) return 'green';
  if (pct >= 80) return 'yellow';
  return 'red';
}

// ============================================================
//  COMPUTE TOTALS
// ============================================================
function computeTotals() {
  monthlyData.fat = employees.reduce((s, e) => s + e.fat, 0);
  monthlyData.orc = employees.reduce((s, e) => s + e.orc, 0);
  monthlyData.vend = employees.reduce((s, e) => s + e.vend, 0);
}

// ============================================================
//  TABS
// ============================================================
function showTab(name) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('section-' + name).classList.add('active');
  document.getElementById('tab-' + name).classList.add('active');

  if (name === 'overview') renderOverview();
  if (name === 'employees') renderEmployees();
  if (name === 'bonuses') renderBonuses();
  if (name === 'improvement') renderImprovement();
  if (name === 'comparison') renderComparison();
  if (name === 'checklist') renderChecklist();
  if (name === 'config') renderConfig();
}

// ============================================================
//  OVERVIEW
// ============================================================
function renderOverview() {
  computeTotals();
  const c = config;
  const kpiGrid = document.getElementById('kpiGrid');
  const chartsRow = document.getElementById('chartsRow');
  const channelsRow = document.getElementById('channelsRow');
  const uploadZone = document.getElementById('uploadZone');

  kpiGrid.style.display = 'grid';
  chartsRow.style.display = 'grid';
  channelsRow.style.display = 'grid';
  uploadZone.style.display = 'none';

  const ticket = monthlyData.vend > 0 ? monthlyData.fat / monthlyData.vend : 0;
  const conv = monthlyData.orc > 0 ? monthlyData.vend / monthlyData.orc : 0;
  const churn = monthlyData.churn;

  document.getElementById('kpi-fat').textContent = fmt(monthlyData.fat);
  document.getElementById('kpi-fat-sub').textContent = 'Meta: ' + fmt(c.globalTarget) + ' (' + pct(monthlyData.fat, c.globalTarget) + '%)';
  document.getElementById('prog-fat').style.width = pct(monthlyData.fat, c.globalTarget) + '%';

  document.getElementById('kpi-ticket').textContent = fmt(ticket);
  document.getElementById('kpi-ticket-sub').textContent = 'Meta: ' + fmt(c.kpiTargets.avgTicket);
  document.getElementById('prog-ticket').style.width = pct(ticket, c.kpiTargets.avgTicket) + '%';

  document.getElementById('kpi-conv').textContent = (conv * 100).toFixed(1) + '%';
  document.getElementById('kpi-conv-sub').textContent = 'Meta: ' + (c.kpiTargets.conversionRate * 100).toFixed(0) + '%';
  document.getElementById('prog-conv').style.width = pct(conv, c.kpiTargets.conversionRate) + '%';

  document.getElementById('kpi-orcamentos').textContent = monthlyData.orc;
  document.getElementById('kpi-orc-sub').textContent = monthlyData.vend + ' convertidos';
  document.getElementById('prog-orc').style.width = Math.min(100, pct(monthlyData.orc, Math.round(c.globalTarget / c.kpiTargets.avgTicket / c.kpiTargets.conversionRate))) + '%';

  document.getElementById('kpi-vendas').textContent = monthlyData.vend;
  document.getElementById('kpi-vend-sub').textContent = 'Ticket médio: ' + fmt(ticket);
  document.getElementById('prog-vend').style.width = Math.min(100, pct(monthlyData.vend, Math.round(c.globalTarget / c.kpiTargets.avgTicket))) + '%';

  document.getElementById('kpi-churn').textContent = churn + '%';
  document.getElementById('prog-churn').style.width = Math.min(100, churn / c.churnMax * 100) + '%';

  // Chart Faturamento
  if (charts.fat) charts.fat.destroy();
  charts.fat = new Chart(document.getElementById('chartFat'), {
    type: 'line',
    data: {
      labels: historicalData.labels,
      datasets: [
        { label: 'Faturamento', data: historicalData.fat, borderColor: '#1a6b3c', backgroundColor: 'rgba(26,107,60,0.1)', tension: 0.4, fill: true, pointRadius: 4 },
        { label: 'Meta', data: historicalData.target, borderColor: '#f59e0b', borderDash: [6,3], tension: 0.4, pointRadius: 0, fill: false }
      ]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } }, scales: { y: { ticks: { callback: v => 'R$' + (v/1000).toFixed(0) + 'k' } }

